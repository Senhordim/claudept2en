{
  "name": "claude-pt-translator",
  "displayName": "Claude Code PT→EN Translator",
  "description": "Automatically translates Portuguese prompts to English before sending to Claude Code",
  "version": "1.0.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudePtTranslator.enable",
        "title": "Claude PT→EN: Enable Translator"
      },
      {
        "command": "claudePtTranslator.disable",
        "title": "Claude PT→EN: Disable Translator"
      },
      {
        "command": "claudePtTranslator.setLibreTranslateUrl",
        "title": "Claude PT→EN: Set LibreTranslate URL"
      },
      {
        "command": "claudePtTranslator.translateSelection",
        "title": "Claude PT→EN: Translate Selected Text"
      }
    ],
    "keybindings": [
      {
        "command": "claudePtTranslator.translateSelection",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Claude PT→EN Translator",
      "properties": {
        "claudePtTranslator.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic PT→EN translation"
        },
        "claudePtTranslator.libreTranslateUrl": {
          "type": "string",
          "default": "https://libretranslate.com",
          "description": "LibreTranslate server URL (use http://localhost:5000 for local)"
        },
        "claudePtTranslator.libreTranslateApiKey": {
          "type": "string",
          "default": "",
          "description": "LibreTranslate API key (leave empty if using local server)"
        },
        "claudePtTranslator.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when text is translated"
        },
        "claudePtTranslator.wrapperScriptPath": {
          "type": "string",
          "default": "",
          "description": "Path to the generated wrapper script (auto-filled on setup)"
        }
      }
    },
    "terminal": {
      "profiles": []
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}
